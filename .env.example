# ============================================================
#  Multi-Tenant AI System — Environment Configuration
#  Copy this file to .env and fill in your values
# ============================================================

# ─── REQUIRED ───────────────────────────────────────────────
# Free API key → https://aistudio.google.com/  (no billing needed)
GEMINI_API_KEY=your_gemini_api_key_here

# ─── APP SETTINGS (optional — defaults shown) ───────────────
APP_NAME="Multi-Tenant AI System"
APP_VERSION=0.1.0
DEBUG=false
LOG_LEVEL=INFO

# ─── LLM SETTINGS ───────────────────────────────────────────
# Groq (Llama-3) for core orchestration, optionally keep Gemini for Image Vision fallbacks
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
GEMINI_MODEL=gemini-2.0-flash
GEMINI_TEMPERATURE=0.1
GEMINI_MAX_TOKENS=2048

# ─── DATABASE ───────────────────────────────────────────────
# SQLite (zero setup) — switch to postgresql+asyncpg://... for production
DATABASE_URL=sqlite+aiosqlite:///./data/app.db

# ─── LOCAL STORAGE ──────────────────────────────────────────
DATA_DIR=./data
QDRANT_PATH=./data/qdrant
QDRANT_COLLECTION=knowledge_base

# ─── EMBEDDINGS (runs locally, no API key needed) ───────────
# Best quality  : nomic-ai/nomic-embed-text-v1.5   (768d, requires trust_remote_code)
# Simple setup  : sentence-transformers/all-MiniLM-L6-v2 (384d, plug-and-play)
EMBEDDING_MODEL=nomic-ai/nomic-embed-text-v1.5
EMBEDDING_DIMENSION=768
EMBEDDING_DEVICE=cpu
# Set to "cuda" if you have a GPU for 10x faster embedding

# ─── RERANKER (runs locally, no API key needed) ─────────────
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# ─── WHISPER SPEECH-TO-TEXT (runs locally, no API key) ──────
# Model sizes: tiny (fastest) | base (recommended) | small | medium | large
WHISPER_MODEL_SIZE=base

# ─── RETRIEVAL ──────────────────────────────────────────────
TOP_K_RETRIEVAL=20          # Candidates fetched from Qdrant
TOP_K_RERANK=5              # Final docs after cross-encoder rerank
MIN_RELEVANCE_SCORE=0.3     # Drop results below this threshold

# ─── CHUNKING ───────────────────────────────────────────────
CHUNK_SIZE=512              # Tokens per chunk
CHUNK_OVERLAP=64            # Overlap between chunks

# ─── SESSION MEMORY ─────────────────────────────────────────
SESSION_TTL_SECONDS=86400   # 24 hours
MAX_CONVERSATION_TURNS=10   # Turns kept in active context

# ─── SPARSE/HYBRID RETRIEVAL (Phase 5) ──────────────────────
# BM25 sparse encoding backend (auto-detected, no manual config needed)
# Install fastembed for best quality: pip install fastembed
# Install scikit-learn for fallback: pip install scikit-learn
# If neither installed, hybrid search gracefully degrades to dense-only
# SPARSE_MODEL=Qdrant/BM25   (used by fastembed backend, change to SPLADE if desired)

# ─── WHATSAPP (Phase 6 — optional for MVP) ──────────────────
# WHATSAPP_VERIFY_TOKEN=my-verify-token
# WHATSAPP_API_TOKEN=your_meta_cloud_api_token
# WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
